# ─────────────────────────────────────────
#  LifeOS — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (use your actual credentials)
DATABASE_URL=postgresql://lifeos_user:your_password@localhost:5432/lifeos_db

# OR individual fields (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lifeos_db
DB_USER=lifeos_user
DB_PASSWORD=your_secure_password

# JWT — generate a strong secret: `openssl rand -hex 64`
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# Bcrypt rounds (10-12 recommended for production)
BCRYPT_ROUNDS=12
